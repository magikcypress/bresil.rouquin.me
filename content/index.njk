---
layout: layouts/base.njk
---

{% for post in collections.posts %}
		<h1><a href="{{ post.url }}" class="postlist-link">{{ post.data.title }}</a></h1>
		<time class="postlist-date" datetime="{{ post.date | dateToISO }}">{{ post.date | readableDate }}</time>
		{{ post.content | safe }}

{% endfor %}
